# Anthropic API
ANTHROPIC_API_KEY=
ADONIS_MODEL=claude-sonnet-4-6

# Prometheus boot-integrity gate.
# First boot with PROMETHEUS_HASH=UNSET prints the current SHA-256 of
# prometheus/fuse.py to stderr. Copy that value here to lock the gate.
PROMETHEUS_HASH=UNSET

# Optional ops webhook for RED/BLACK fuse decisions.
PROMETHEUS_ALERT_WEBHOOK=

# Hermes HTTP entrypoint (POST /ask, /task ; GET /health, /ges, /audit)
HERMES_PORT=8088

# Obsidian long-term memory — leave OBSIDIAN_API blank to disable.
# Requires the obsidian-local-rest-api plugin in the vault.
OBSIDIAN_API=
OBSIDIAN_TOKEN=

# MCP servers — JSON list. Each entry needs name + command.
# Example (uncomment and edit):
# MCP_SERVERS=[{"name":"github","command":["mcp-server-github"],"env":{"GH_TOKEN":"..."}},{"name":"fs","command":["mcp-server-filesystem","--root","/vault"]}]
MCP_SERVERS=

LOG_LEVEL=INFO
